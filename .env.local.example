# Get your key at https://steamcommunity.com/dev/apikey
# Your Steam profile must be PUBLIC for the achievement endpoints to work
STEAM_API_KEY=your_steam_key_here

# Optional - only needed if you want LLM-based difficulty scoring
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Supabase — used for caching Steam API responses and LLM judgements
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional — auto-login with this SteamID64 (public value, safe to expose)
NEXT_PUBLIC_DEFAULT_STEAM_ID=
